generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id    String @id @default(uuid())
  name  String @unique
  label String
  color String
  order Int    @default(0)
}

model Task {
  id                   String    @id @default(uuid())
  title                String
  description          String?
  status               String
  project              String
  date                 DateTime?
  createdAt            DateTime  @default(now())
  completedAt          DateTime?
  order                Int       @default(0)
  totalTrackedSeconds  Int       @default(0)
  activeTimerStartedAt DateTime?
  resumeTimerOnExit    Boolean   @default(false)
}
